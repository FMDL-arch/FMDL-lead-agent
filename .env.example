# Copy this file to .env and fill in real values. Never commit .env to GitHub.

# Claude API - get from console.anthropic.com
ANTHROPIC_API_KEY=

# Meta / WhatsApp Cloud API - get from developers.facebook.com > your App > WhatsApp
WHATSAPP_ACCESS_TOKEN=
META_VERIFY_TOKEN=choose-any-random-string-yourself
META_PAGE_ACCESS_TOKEN=

# Your two WhatsApp phone_number_ids (NOT the phone numbers themselves - find these
# in Meta Business Manager > WhatsApp Accounts > API Setup)
FMDL_PHONE_NUMBER_ID=
PRODUCTS_PHONE_NUMBER_ID=

# Supabase - get from supabase.com after creating a free project
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Cal.com - your public booking link
CALCOM_BOOKING_LINK=https://cal.com/your-fmdl-link/intro-call

# Razorpay - get from Razorpay Dashboard > Settings > Webhooks
RAZORPAY_WEBHOOK_SECRET=

PORT=3000
