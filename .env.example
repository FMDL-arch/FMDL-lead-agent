# Copy this file to .env and fill in real values. Never commit .env to GitHub.

# Claude API - get from console.anthropic.com
ANTHROPIC_API_KEY=

# Meta / WhatsApp Cloud API - get from developers.facebook.com > your App > WhatsApp
WHATSAPP_ACCESS_TOKEN=
META_VERIFY_TOKEN=choose-any-random-string-yourself
META_PAGE_ACCESS_TOKEN=

# Your WhatsApp phone_number_id (NOT the phone number itself - find this
# in Meta Business Manager > WhatsApp Accounts > API Setup)
FMDL_PHONE_NUMBER_ID=

# Supabase - get from supabase.com after creating a free project
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Cal.com - your public booking link
CALCOM_BOOKING_LINK=https://cal.com/your-fmdl-link/intro-call

# Links Shipra (the AI) shares when a lead asks for the website or Instagram
FMDL_WEBSITE_URL=
FMDL_INSTAGRAM_URL=

# WhatsApp template for re-engaging leads who never messaged us (or it's been
# over 24h) - e.g. leads captured by Meta Lead Ads that we need to reach out
# to first. Must match a template APPROVED in WhatsApp Manager exactly.
# See README for setup steps.
FMDL_REENGAGE_TEMPLATE_NAME=fmdl_lead_reengage
FMDL_REENGAGE_TEMPLATE_LANG=en

# Backup lead poller (routes/sync.js) - Meta's leadgen webhook is "best effort"
# per their own docs and can be delayed or dropped, so an external scheduler
# (cron-job.org) hits GET /cron/sync-leads?token=<CRON_SYNC_SECRET> every
# 15 minutes to re-check the Graph API and import anything the webhook missed.
# META_PAGE_ID is the FMDL Architects Facebook Page ID (462321077302806).
# CRON_SYNC_SECRET is any random string you choose - it just stops strangers
# from hitting this public URL and triggering syncs.
META_PAGE_ID=462321077302806
CRON_SYNC_SECRET=

# Team dashboard password - choose your own, set it as an env var in Render too
DASHBOARD_PASSWORD=

PORT=3000
